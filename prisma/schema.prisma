generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  TRAINER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CourtType {
  INDOOR
  OUTDOOR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentType {
  BOOKING
  RESCHEDULE_FEE
  RESCHEDULE_DIFFERENCE
  CANCELLATION_REFUND
  CANCELLATION_PENALTY
  WAITLIST_CLAIM
  ADMIN_ADJUSTMENT
  OVERTIME_ADJUSTMENT
}

enum BookingCheckoutSessionStatus {
  OPEN
  PAYMENT_FAILED
  FINALIZING
  COMPLETED
  EXPIRED
  REFUND_PENDING
  REFUNDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
  REMOVED
}

enum WaitlistStatus {
  WAITING
  OFFERED
  ACCEPTED
  EXPIRED
  REMOVED
  CANCELLED
}

enum LightingActionSource {
  SYSTEM
  ADMIN
}

enum LightingActionType {
  AUTO_ON
  AUTO_OFF
  MANUAL_ON
  MANUAL_OFF
  EXTEND
  TEST_SWITCH
  STATUS_SYNC
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  firstName          String?
  lastName           String?
  avatarUrl          String?
  level              String?
  favoriteCourt      String?
  preferredTimeSlots String[]  @default([])
  isVerified         Boolean   @default(false)
  phone              String?
  expoPushToken      String?
  gender             Gender
  notifyPush         Boolean   @default(false)
  notifySms          Boolean   @default(false)
  notifyEmail        Boolean   @default(true)
  tokenVersion       Int       @default(0)
  role               Role      @default(USER)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  userOtps                UserOtp[]
  organizerBookings       Booking[]                @relation("OrganizerBookings")
  bookingParticipants     BookingParticipant[]
  sentInvitations         BookingInvitation[]      @relation("SentInvitations")
  receivedInvitations     BookingInvitation[]      @relation("ReceivedInvitations")
  paymentTransactions     PaymentTransaction[]
  waitlistEntries         WaitlistEntry[]
  courtRatings            CourtRating[]
  bookingStatusChanges    BookingStatusHistory[]   @relation("BookingStatusChangedBy")
  checkInBookings         Booking[]                @relation("CheckInByUser")
  lightingActions         LightingActionLog[]      @relation("LightingActionRequestedBy")
  bookingCheckoutSessions BookingCheckoutSession[]

  @@map("users")
}

model UserOtp {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("user_otps")
}

model Court {
  id                   String    @id @default(uuid())
  name                 String
  type                 CourtType
  surface              String
  hasLighting          Boolean   @default(false)
  lightingDeviceId     String[]  @default([])
  lightingEnabled      Boolean   @default(false)
  lightingOnOffsetMin  Int       @default(0)
  lightingOffBufferMin Int       @default(5)
  quietHoursEnabled    Boolean   @default(true)
  quietHoursStart      String    @default("22:00")
  quietHoursEnd        String    @default("06:00")
  quietHoursHardBlock  Boolean   @default(true)
  rules                String?
  pricePerHour         Decimal   @db.Decimal(10, 2)
  currency             String    @default("MZN")
  maxPlayers           Int       @default(4)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  images                  CourtImage[]
  bookings                Booking[]
  bookingCheckoutSessions BookingCheckoutSession[]
  ratings                 CourtRating[]
  waitlistEntries         WaitlistEntry[]
  lightingActionLogs      LightingActionLog[]
  lightingDeviceState     LightingDeviceState?

  @@index([isActive, deletedAt])
  @@map("courts")
}

model CourtImage {
  id        String   @id @default(uuid())
  courtId   String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId, sortOrder])
  @@map("court_images")
}

model Booking {
  id                    String        @id @default(uuid())
  courtId               String
  organizerId           String
  startAt               DateTime
  endAt                 DateTime
  durationMinutes       Int
  totalPrice            Decimal       @db.Decimal(10, 2)
  currency              String        @default("MZN")
  paidAmount            Decimal       @default(0) @db.Decimal(10, 2)
  status                BookingStatus @default(PENDING)
  paymentDueAt          DateTime?
  cancelledAt           DateTime?
  cancellationReason    String?
  checkedInAt           DateTime?
  checkInToken          String?
  checkInTokenExpiresAt DateTime?
  checkInByUserId       String?
  isAdminForced         Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  court         Court @relation(fields: [courtId], references: [id])
  organizer     User  @relation("OrganizerBookings", fields: [organizerId], references: [id])
  checkInByUser User? @relation("CheckInByUser", fields: [checkInByUserId], references: [id], onDelete: SetNull)

  participants       BookingParticipant[]
  invitations        BookingInvitation[]
  statusHistory      BookingStatusHistory[]
  payments           PaymentTransaction[]
  checkoutSession    BookingCheckoutSession?
  ratings            CourtRating[]
  waitlistEntries    WaitlistEntry[]         @relation("WaitlistBooking")
  lightingActionLogs LightingActionLog[]

  @@index([courtId, startAt, endAt])
  @@index([organizerId, startAt])
  @@index([status, paymentDueAt])
  @@map("bookings")
}

model BookingParticipant {
  id          String            @id @default(uuid())
  bookingId   String
  userId      String
  status      ParticipantStatus @default(INVITED)
  isOrganizer Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([bookingId, userId])
  @@index([userId, status])
  @@map("booking_participants")
}

model BookingInvitation {
  id            String           @id @default(uuid())
  bookingId     String
  inviterUserId String
  invitedUserId String?
  inviteeEmail  String?
  token         String           @unique
  status        InvitationStatus @default(PENDING)
  expiresAt     DateTime
  respondedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  inviterUser User    @relation("SentInvitations", fields: [inviterUserId], references: [id])
  invitedUser User?   @relation("ReceivedInvitations", fields: [invitedUserId], references: [id])

  @@index([bookingId, status])
  @@index([invitedUserId, status])
  @@map("booking_invitations")
}

model BookingStatusHistory {
  id              String         @id @default(uuid())
  bookingId       String
  fromStatus      BookingStatus?
  toStatus        BookingStatus
  reason          String?
  changedByUserId String?
  createdAt       DateTime       @default(now())

  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedByUser User?   @relation("BookingStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([bookingId, createdAt])
  @@map("booking_status_history")
}

model PaymentTransaction {
  id          String        @id @default(uuid())
  bookingId   String
  userId      String
  type        PaymentType
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("MZN")
  reference   String        @unique
  metadata    Json?
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([bookingId, status])
  @@index([userId, type])
  @@map("payment_transactions")
}

model BookingCheckoutSession {
  id                 String                       @id @default(uuid())
  organizerId        String
  courtId            String
  bookingId          String?                      @unique
  startAt            DateTime
  endAt              DateTime
  durationMinutes    Int
  amount             Decimal                      @db.Decimal(10, 2)
  currency           String                       @default("MZN")
  reference          String                       @unique
  participantUserIds Json?
  status             BookingCheckoutSessionStatus @default(OPEN)
  expiresAt          DateTime
  paysuitePaymentId  String?
  checkoutUrl        String?
  paymentMethod      String?
  refundId           String?
  failureReason      String?
  paidAt             DateTime?
  completedAt        DateTime?
  refundedAt         DateTime?
  metadata           Json?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  organizer User     @relation(fields: [organizerId], references: [id])
  court     Court    @relation(fields: [courtId], references: [id])
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([courtId, startAt, endAt, status])
  @@index([organizerId, startAt, status])
  @@index([status, expiresAt])
  @@index([paysuitePaymentId])
  @@index([refundId])
  @@map("booking_checkout_sessions")
}

model WaitlistEntry {
  id             String         @id @default(uuid())
  courtId        String
  userId         String
  bookingId      String?
  startAt        DateTime
  endAt          DateTime
  status         WaitlistStatus @default(WAITING)
  position       Int
  offeredAt      DateTime?
  offerExpiresAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  court   Court    @relation(fields: [courtId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  booking Booking? @relation("WaitlistBooking", fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([courtId, userId, startAt, endAt])
  @@index([courtId, startAt, endAt, status])
  @@index([userId, status])
  @@map("waitlist_entries")
}

model CourtRating {
  id               String   @id @default(uuid())
  courtId          String
  bookingId        String
  userId           String
  courtScore       Int
  cleanlinessScore Int
  lightingScore    Int
  comment          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  court   Court   @relation(fields: [courtId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([bookingId, userId])
  @@index([courtId, createdAt])
  @@map("court_ratings")
}

model LightingActionLog {
  id                String               @id @default(uuid())
  courtId           String
  bookingId         String?
  requestedByUserId String?
  source            LightingActionSource
  action            LightingActionType
  reason            String?
  success           Boolean
  attempts          Int                  @default(1)
  errorCode         String?
  errorMessage      String?
  createdAt         DateTime             @default(now())

  court           Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  booking         Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  requestedByUser User?    @relation("LightingActionRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([courtId, createdAt])
  @@index([bookingId, createdAt])
  @@index([success, createdAt])
  @@map("lighting_action_logs")
}

model LightingDeviceState {
  id                 String              @id @default(uuid())
  courtId            String              @unique
  isOnline           Boolean             @default(false)
  lastPingAt         DateTime?
  lastCommandAt      DateTime?
  lastCommandAction  LightingActionType?
  lastCommandSuccess Boolean?
  lastError          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([isOnline, updatedAt])
  @@map("lighting_device_states")
}
